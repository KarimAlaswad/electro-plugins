{
	"name": "electrobun-react-tailwind-vite",
	"version": "1.0.0",
	"description": "Electrobun app with React, Tailwind CSS, and Vite HMR",
	"scripts": {
		"start": "bun run build:plugins && vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary",
		"build:plugins": "bun scripts/build-plugins.ts"
	},
	"dependencies": {
		"@steipete/sweet-cookie": "0.4.0",
		"electrobun": "1.18.1",
		"preact": "^10.29.2",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"vue": "^3.5.38",
		"youtubei.js": "^17.0.1"
	},
	"devDependencies": {
		"@preact/preset-vite": "^2.10.5",
		"@sveltejs/vite-plugin-svelte": "*",
		"@types/bun": "latest",
		"@types/node": "^26.1.0",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.3.4",
		"@vitejs/plugin-vue": "^6.0.7",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.1.0",
		"postcss": "^8.4.49",
		"svelte": "*",
		"tailwindcss": "^3.4.16",
		"typescript": "^5.7.2",
		"vite": "^6.0.3",
		"vite-plugin-css-injected-by-js": "^5.0.1"
	}
}
